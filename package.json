{
  "name": "catzlauncher",
  "version": "1.0.0",
  "description": "CatzLauncher - Modpack Launcher for Minecraft",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "dist": "electron-builder --publish=never"
  },
  "keywords": [
    "minecraft",
    "launcher",
    "modpack",
    "electron"
  ],
  "author": "CatzLauncher Team",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.6.4"
  },
  "dependencies": {
    "adm-zip": "^0.5.10",
    "assert-plus": "^1.0.0",
    "electron-store": "^8.1.0",
    "fs-extra": "^11.3.0",
    "keytar": "^7.9.0",
    "minecraft-launcher-core": "^3.18.2",
    "node-7z": "^2.1.2",
    "node-fetch": "^2.7.0"
  },
  "build": {
    "appId": "com.catzlauncher.app",
    "productName": "CatzLauncher",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/exe/app.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/exe/app.ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/exe/app.ico"
    }
  }
}
