{
  "name": "catzlauncher-web",
  "version": "1.0.0",
  "description": "Launcher de modpacks Minecraft moderne en HTML/WebKit",
  "main": "src/electron/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm run server\" \"npm run electron\"",
    "server": "node src/backend/server.js",
    "electron": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "keywords": [
    "minecraft",
    "launcher",
    "modpacks",
    "electron",
    "webkit"
  ],
  "author": "CatzLauncher Team",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.6.4"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "child_process": "^1.0.2",
    "crypto-js": "^4.2.0",
    "express": "^4.18.2",
    "fs-extra": "^11.1.1",
    "node-fetch": "^3.3.2",
    "os": "^0.1.2",
    "package": "^1.0.1",
    "path": "^0.12.7",
    "sqlite3": "^5.1.6"
  },
  "build": {
    "appId": "com.catzlauncher.web",
    "productName": "CatzLauncher Web",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icons/app.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icons/app.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icons/app.png"
    }
  }
}
